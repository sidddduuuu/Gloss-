# ---------------------------------------------------------------------------
# Real LLM explanations. Copy this file to .env.local and fill in the three
# values, then restart `npm run dev`. Works with ANY OpenAI-compatible endpoint
# (Butterbase AI gateway, OpenAI, OpenRouter, Groq, Nebius, together.ai, …).
#
# With these unset, Gloss runs on the built-in mock (demo phrases only).
# ---------------------------------------------------------------------------

# Base URL of the provider (no trailing /v1 — the app appends /v1/chat/completions).
#   Butterbase gateway : https://<your-project>.butterbase.dev/gateway
#   OpenAI             : https://api.openai.com
#   OpenRouter         : https://openrouter.ai/api
#   Groq               : https://api.groq.com/openai
LLM_BASE_URL=

# Your API key for that provider.
LLM_API_KEY=

# Model id to use, e.g. gpt-4o-mini, llama-3.3-70b-versatile, meta-llama/llama-3.3-70b-instruct
LLM_MODEL=

# Set to 1 to force the mock even when the above are filled (useful for offline rehearsal).
MOCK_EXPLAIN=
